<UserControl x:Class="ToolVPS.Views.RemoteTerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Connection panel -->
        <GroupBox Grid.Row="0" Header="SSH Connection" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Host + Port -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Host:" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,4"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Port:" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox   Grid.Row="0" Grid.Column="3" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,4"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="User:" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox   Grid.Row="0" Grid.Column="5" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                <!-- Auth mode -->
                <RadioButton Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                             Content="Password" IsChecked="{Binding UsePassword}" Margin="0,0,12,4"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Password:" VerticalAlignment="Center"
                           Margin="0,0,6,4"
                           Visibility="{Binding UsePassword, Converter={StaticResource BoolToVis}}"/>
                <PasswordBox Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="3"
                             x:Name="PasswordBox" Margin="0,0,0,4"
                             Visibility="{Binding UsePassword, Converter={StaticResource BoolToVis}}"/>

                <!-- Key file row -->
                <RadioButton Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                             Content="Private Key" Margin="0,0,12,0"
                             IsChecked="{Binding UsePassword, Converter={StaticResource InverseBool}}"/>
                <TextBox Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3"
                         Text="{Binding PrivateKeyPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0"
                         IsEnabled="{Binding UsePassword, Converter={StaticResource InverseBool}}"/>
                <Button Grid.Row="2" Grid.Column="5"
                        Content="Connect" Command="{Binding ConnectCommand}"
                        IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBool}}"
                        HorizontalAlignment="Right" Padding="12,4"/>
            </Grid>
        </GroupBox>

        <!-- Main workspace: terminal left, file manager right -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="370"/>
            </Grid.ColumnDefinitions>

            <!-- Terminal -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#555" BorderThickness="1" Background="#1E1E1E">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  x:Name="TerminalScroll">
                        <TextBlock Text="{Binding TerminalOutput}"
                                   FontFamily="Consolas" FontSize="13"
                                   Foreground="#D4D4D4" Padding="6"
                                   TextWrapping="NoWrap"/>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="1" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             x:Name="CmdInput"
                             KeyDown="CmdInput_KeyDown"/>
                    <Button Grid.Column="1" Content="Send" Command="{Binding SendCommandCommand}" Padding="10,4" Margin="4,0,4,0"/>
                    <Button Grid.Column="2" Content="Disconnect" Command="{Binding DisconnectCommand}"
                            IsEnabled="{Binding IsConnected}" Padding="10,4"/>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDD"/>

            <!-- File manager -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="220"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Path bar -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <Button Content="Up" Command="{Binding NavigateUpCommand}" Padding="8,2" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding CurrentRemotePath}" VerticalAlignment="Center"
                               FontFamily="Consolas" FontSize="12" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- File list -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding FileEntries}"
                         SelectedItem="{Binding SelectedFile}"
                         BorderThickness="1" BorderBrush="#CCCCCC"
                         MouseDoubleClick="FileList_DoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding IsDirectory, Converter={StaticResource DirIcon}}" Margin="0,0,6,0" Foreground="#0078D4"/>
                                <TextBlock Text="{Binding Name}" Width="160" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding SizeDisplay}" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Create new folder/file -->
                <Grid Grid.Row="2" Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" FontSize="12"
                             ToolTip="Enter name for new folder or file"/>
                    <Button Grid.Column="1" Content="+ Folder" Command="{Binding CreateDirectoryCommand}"
                            Padding="6,2" Margin="4,0,4,0"/>
                    <Button Grid.Column="2" Content="+ File" Command="{Binding CreateFileCommand}"
                            Padding="6,2"/>
                </Grid>

                <!-- File actions -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,4">
                    <Button Content="Open" Command="{Binding OpenFileOrDirectoryCommand}" Padding="8,2" Margin="0,0,6,0"/>
                    <Button Content="Refresh" Command="{Binding RefreshFilesCommand}" Padding="8,2"/>
                </StackPanel>

                <!-- File editor -->
                <TextBox Grid.Row="4"
                         Text="{Binding FileEditorContent, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12"
                         BorderThickness="1" BorderBrush="#CCCCCC"/>

                <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="{Binding EditingFilePath}" FontSize="11" Foreground="Gray"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Width="180"/>
                    <Button Content="Save File" Command="{Binding SaveFileCommand}" Padding="8,2" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Margin="0,4,0,0"
                   Foreground="Gray" FontSize="12"/>
    </Grid>
</UserControl>
