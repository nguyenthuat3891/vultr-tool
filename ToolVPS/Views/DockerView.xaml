<UserControl x:Class="ToolVPS.Views.DockerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Check Docker" Command="{Binding CheckDockerCommand}"
                    Padding="10,4" Margin="0,0,8,0" FontWeight="SemiBold"/>
            <Button Content="Refresh All"  Command="{Binding RefreshAllCommand}"
                    Padding="10,4" Margin="0,0,16,0"/>
            <TextBlock Text="{Binding DockerVersion}" VerticalAlignment="Center"
                       Foreground="#0078D4" FontWeight="SemiBold"/>
            <TextBlock Text="  |  " VerticalAlignment="Center" Foreground="#CCC"
                       Visibility="{Binding DockerInstalled, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Text="{Binding DockerInfo}" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="11"
                       Visibility="{Binding DockerInstalled, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <!-- Main split: Containers (left) | Compose + Tunnels (right) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Containers -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="160"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Containers" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="▶ Start"    Command="{Binding StartContainerCommand}"   Padding="8,2" Margin="0,0,4,0"/>
                    <Button Content="■ Stop"     Command="{Binding StopContainerCommand}"    Padding="8,2" Margin="0,0,4,0"/>
                    <Button Content="↺ Restart"  Command="{Binding RestartContainerCommand}" Padding="8,2" Margin="0,0,4,0"/>
                    <Button Content="Logs"       Command="{Binding ViewLogsCommand}"         Padding="8,2"/>
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Containers}"
                          SelectedItem="{Binding SelectedContainer}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" GridLinesVisibility="Horizontal"
                          BorderThickness="1" BorderBrush="#CCC">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header=""       Binding="{Binding StateIcon}"    Width="20"/>
                        <DataGridTextColumn Header="Name"   Binding="{Binding DisplayName}"  Width="*"/>
                        <DataGridTextColumn Header="Image"  Binding="{Binding Image}"        Width="140"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}"       Width="120"/>
                        <DataGridTextColumn Header="Ports"  Binding="{Binding Ports}"        Width="140"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Foreground" Value="#16A34A"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                    <Setter Property="Foreground" Value="#DC2626"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>

                <!-- Output / logs -->
                <Border Grid.Row="2" BorderBrush="#CCC" BorderThickness="1"
                        Background="#1E1E1E" Margin="0,6,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="LogScroll">
                        <TextBox Text="{Binding OutputLog, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 FontFamily="Consolas" FontSize="11"
                                 Foreground="#D4D4D4" Background="Transparent"
                                 BorderThickness="0" Padding="6"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDD"/>

            <!-- RIGHT: Compose services + SSH tunnels -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Compose services -->
                <TextBlock Grid.Row="0" Text="Docker Compose Services" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ComposeServices}"
                          SelectedItem="{Binding SelectedService}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" GridLinesVisibility="Horizontal"
                          BorderThickness="1" BorderBrush="#CCC">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header=""        Binding="{Binding StateIcon}" Width="20"/>
                        <DataGridTextColumn Header="Service" Binding="{Binding Service}"  Width="*"/>
                        <DataGridTextColumn Header="Name"    Binding="{Binding Name}"     Width="120"/>
                        <DataGridTextColumn Header="Status"  Binding="{Binding Status}"   Width="100"/>
                        <DataGridTextColumn Header="Ports"   Binding="{Binding Ports}"    Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- SSH Tunnel panel -->
                <Border Grid.Row="2" Margin="0,8,0,0"
                        Background="#FFFBEB" BorderBrush="#F59E0B" BorderThickness="1"
                        CornerRadius="4" Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="SSH Port Tunnels  (127.0.0.1 → remote)"
                                   FontWeight="Bold" Foreground="#92400E" Margin="0,0,0,8"/>

                        <!-- Custom tunnel input -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="88"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="48"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"  Text="Label:"       VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                            <TextBox   Grid.Column="1"  Text="{Binding TunnelLabel,       UpdateSourceTrigger=PropertyChanged}" FontSize="11"/>
                            <TextBlock Grid.Column="3"  Text="Local:"       VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                            <TextBox   Grid.Column="4"  Text="{Binding TunnelLocalPort,   UpdateSourceTrigger=PropertyChanged}" FontSize="11"/>
                            <TextBlock Grid.Column="6"  Text="Remote host:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                            <TextBox   Grid.Column="7"  Text="{Binding TunnelRemoteHost,  UpdateSourceTrigger=PropertyChanged}" FontSize="11"/>
                            <TextBlock Grid.Column="9"  Text="Port:"        VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                            <TextBox   Grid.Column="10" Text="{Binding TunnelRemotePort,  UpdateSourceTrigger=PropertyChanged}" FontSize="11"/>
                        </Grid>

                        <!-- Quick preset + Add buttons -->
                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="Quick: " VerticalAlignment="Center"
                                       Foreground="Gray" FontSize="11" Margin="0,0,6,0"/>
                            <Button Content="🐘 Postgres :5432" Command="{Binding QuickPostgresTunnelCommand}"
                                    Padding="8,3" Margin="0,0,4,4" Background="#3B82F6" Foreground="White" FontSize="11"/>
                            <Button Content="🐬 MySQL :3306"    Command="{Binding QuickMysqlTunnelCommand}"
                                    Padding="8,3" Margin="0,0,4,4" Background="#F59E0B" Foreground="White" FontSize="11"/>
                            <Button Content="Redis :6379"       Command="{Binding QuickRedisTunnelCommand}"
                                    Padding="8,3" Margin="0,0,4,4" Background="#DC2626" Foreground="White" FontSize="11"/>
                            <Button Content="+ Add Custom"      Command="{Binding AddTunnelCommand}"
                                    Padding="8,3" Margin="0,0,0,4" Background="#16A34A" Foreground="White"
                                    FontSize="11" FontWeight="SemiBold"/>
                        </WrapPanel>

                        <!-- Active tunnels list -->
                        <ItemsControl ItemsSource="{Binding ActiveTunnels}" MaxHeight="120">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#BBF7D0" BorderThickness="1" Background="#F0FDF4"
                                            CornerRadius="3" Padding="6,4" Margin="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="✓ " Foreground="#16A34A" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding DisplayText}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Remove"
                                                    Command="{Binding DataContext.RemoveTunnelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="6,2" FontSize="11" Background="#FEE2E2" Foreground="#DC2626"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="2" IsIndeterminate="{Binding IsBusy}"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                     Height="4" Margin="0,4,0,0"/>

        <!-- Status bar -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Margin="0,4,0,0"
                   Foreground="Gray" FontSize="12"/>
    </Grid>
</UserControl>
