<UserControl x:Class="ToolVPS.Views.InstanceListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top action bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="Refresh"               Command="{Binding RefreshCommand}"        Padding="10,4" Margin="0,0,8,0"/>
            <Button Content="Reboot"                Command="{Binding RebootCommand}"         Padding="10,4" Margin="0,0,8,0"/>
            <Button Content="Open Local SSH Window" Command="{Binding OpenLocalSshCommand}"   Padding="10,4"/>
        </StackPanel>

        <!-- Instance grid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Instances}"
                  SelectedItem="{Binding SelectedInstance}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  BorderThickness="1" BorderBrush="#CCCCCC">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Label"   Binding="{Binding DisplayLabel}" Width="160"/>
                <DataGridTextColumn Header="IP"      Binding="{Binding MainIp}"       Width="130"/>
                <DataGridTextColumn Header="Status"  Binding="{Binding StatusBadge}"  Width="80"/>
                <DataGridTextColumn Header="Region"  Binding="{Binding Region}"        Width="80"/>
                <DataGridTextColumn Header="Plan"    Binding="{Binding Plan}"          Width="120"/>
                <DataGridTextColumn Header="OS"      Binding="{Binding Os}"            Width="*"/>
                <DataGridTextColumn Header="vCPU"    Binding="{Binding VcpuCount}"     Width="55"/>
                <DataGridTextColumn Header="RAM"     Binding="{Binding Ram}"           Width="65"/>
                <DataGridTextColumn Header="Created" Binding="{Binding DateCreated}"   Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="2" IsIndeterminate="{Binding IsBusy}"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                     Height="4" Margin="0,4,0,0"/>

        <!-- Quick SSH Connect panel -->
        <Border Grid.Row="3" Margin="0,8,0,0"
                Background="#F0F7FF" BorderBrush="#0078D4" BorderThickness="1,1,1,1"
                CornerRadius="4" Padding="10,8">
            <StackPanel>
                <TextBlock Text="Quick SSH Connect" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Host / IP:" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding QuickHost, UpdateSourceTrigger=PropertyChanged}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Port:" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="0" Grid.Column="4" Text="{Binding QuickPort, UpdateSourceTrigger=PropertyChanged}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="0" Grid.Column="6" Text="User:" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="0" Grid.Column="7" Text="{Binding QuickUsername, UpdateSourceTrigger=PropertyChanged}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="0" Grid.Column="9" Text="Password:" VerticalAlignment="Center"/>
                    <PasswordBox Grid.Row="0" Grid.Column="10" x:Name="QuickPasswordBox"
                                 PasswordChanged="QuickPasswordBox_Changed"
                                 VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Key (optional):" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="8"
                               Text="{Binding QuickKeyPath, UpdateSourceTrigger=PropertyChanged}"
                               FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button    Grid.Row="1" Grid.Column="9" Content="..." Command="{Binding BrowseQuickKeyCommand}"
                               Padding="6,2" VerticalAlignment="Center"/>

                    <Button    Grid.Row="1" Grid.Column="10"
                               Content="  SSH Connect  "
                               Command="{Binding QuickConnectCommand}"
                               Padding="14,5" VerticalAlignment="Center"
                               Background="#0078D4" Foreground="White"
                               FontWeight="Bold" FontSize="13"
                               Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#005A9E"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" Margin="0,4,0,0"
                   Foreground="Gray" FontSize="12"/>
    </Grid>
</UserControl>
