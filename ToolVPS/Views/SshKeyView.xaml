<UserControl x:Class="ToolVPS.Views.SshKeyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Generate new key pair -->
        <GroupBox Grid.Row="0" Header="Generate New SSH Key Pair" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Key Name:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                           Text="{Binding KeyName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Save To:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,4"/>
                <Button    Grid.Row="1" Grid.Column="2" Content="Browse…" Command="{Binding BrowseSaveDirectoryCommand}" Padding="8,2" Margin="0,0,0,4"/>

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal">
                    <TextBlock Text="Key Type:" VerticalAlignment="Center" Margin="0,4,6,0"/>
                    <ComboBox ItemsSource="{Binding KeyTypes}"
                              SelectedItem="{Binding KeyType}"
                              Width="80" Margin="0,4,12,0" VerticalAlignment="Center"/>
                    <Button Content="Generate Key Pair" Command="{Binding GenerateKeyCommand}"
                            Padding="12,4" Margin="0,4,8,0"/>
                    <TextBlock Text="Keys saved as  keyname  (private) and  keyname.pub  (public)"
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Load existing key from disk -->
        <GroupBox Grid.Row="1" Header="Load Existing Key" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Private Key:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox   Grid.Column="1" Text="{Binding ExistingKeyPath, Mode=OneWay}"
                           IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button    Grid.Column="2" Content="Browse Private Key…"
                           Command="{Binding BrowseExistingKeyCommand}" Padding="8,4" Margin="0,0,8,0"/>
                <Button    Grid.Column="3" Content="Copy Public Key"
                           Command="{Binding CopyPublicKeyCommand}" Padding="8,4"/>
            </Grid>
        </GroupBox>

        <!-- Install key → server (ssh-copy-id) -->
        <GroupBox Grid.Row="2" Padding="8" Margin="0,0,0,8">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Install Key → Server" FontWeight="SemiBold"/>
                    <TextBlock Text="  (like ssh-copy-id — connects with password once, installs the public key)"
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Host:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   Grid.Column="1" Text="{Binding InstallHost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="2" Text="Port:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   Grid.Column="3" Text="{Binding InstallPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="4" Text="User:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   Grid.Column="5" Text="{Binding InstallUser, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="6" Text="Password:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <PasswordBox Grid.Column="7" x:Name="InstallPasswordBox"
                             PasswordChanged="InstallPasswordBox_Changed" Margin="0,0,8,0"/>
                <Button    Grid.Column="8"
                           Content="Install Public Key"
                           Command="{Binding InstallKeyCommand}"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                           Padding="12,4" Background="#16A34A" Foreground="White" FontWeight="SemiBold"/>
            </Grid>
        </GroupBox>

        <!-- Public key display -->
        <GroupBox Grid.Row="3" Header="Public Key  (paste this into authorized_keys if installing manually)" Padding="8">
            <TextBox x:Name="PublicKeyBox"
                     IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="11"/>
        </GroupBox>

        <!-- Status -->
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" Margin="0,4,0,0"
                   Foreground="Gray" FontSize="12" TextWrapping="Wrap"/>
    </Grid>
</UserControl>
