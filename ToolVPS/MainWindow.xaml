<Window x:Class="ToolVPS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="ToolVPS — Vultr &amp; SSH Manager"
        Icon="app.ico"
        Height="700" Width="1100"
        MinWidth="900" MinHeight="550">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="#0078D4" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ToolVPS" FontSize="18" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Manual SSH via instance IP — no Vultr API key required" 
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Navigation bar -->
        <Border Grid.Row="1" Background="#F3F3F3" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="Instances" Command="{Binding ShowInstancesCommand}"
                        Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="SSH Keys"  Command="{Binding ShowSshKeysCommand}"
                        Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Docker"   Command="{Binding ShowDockerCommand}"
                        Padding="12,4" Margin="0,0,8,0" Background="#1D4ED8" Foreground="White"/>
                <TextBlock Text="|" VerticalAlignment="Center" Foreground="#CCCCCC" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="Gray" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Content area — driven by CurrentView + DataTemplates in App.xaml -->
        <ContentControl Grid.Row="2" Content="{Binding CurrentView}"/>

        <!-- Global status bar -->
        <Border Grid.Row="3" Background="#F3F3F3" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="8,3">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="Gray"/>
        </Border>
    </Grid>
</Window>
